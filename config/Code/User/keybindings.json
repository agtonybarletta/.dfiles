[
  //  _   _ _   _ ____  _____ _____ 
  // | | | | \ | / ___|| ____|_   _|
  // | | | |  \| \___ \|  _|   | |  
  // | |_| | |\  |___) | |___  | |  
  //  \___/|_| \_|____/|_____| |_|  
  //                                
  //  _              _     _           _ _                 
  // | | _____ _   _| |__ (_)_ __   __| (_)_ __   __ _ ___ 
  // | |/ / _ \ | | | '_ \| | '_ \ / _` | | '_ \ / _` / __|
  // |   <  __/ |_| | |_) | | | | | (_| | | | | | (_| \__ \
  // |_|\_\___|\__, |_.__/|_|_| |_|\__,_|_|_| |_|\__, |___/
  //           |___/                             |___/     
  {
    "key": "alt+h",
    "command": "-testing.toggleTestingPeekHistory",
    "when": "testing.isPeekVisible"
  },
  {
    "key": "alt+h",
    "command": "-editor.action.accessibilityHelpOpenHelpLink",
    "when": "accessibilityHelpIsShown"
  },
  {
    "key": "alt+l",
    "command": "-toggleSearchEditorContextLines",
    "when": "inSearchEditor"
  },
  {
    "key": "alt+l",
    "command": "-toggleFindInSelection",
    "when": "editorFocus"
  },
  {
    "key": "ctrl+shift+v",
    "command": "-markdown.showPreview",
    "when": "!notebookEditorFocused && editorLangId == 'markdown'"
  },
  {
    "key": "ctrl+n",
    "command": "-workbench.action.files.newUntitledFile"
  },
  {
    "key": "ctrl+\\",
    "command": "-workbench.action.splitEditor"
  },
  {
    "key": "alt+up",
    "command": "-editor.action.moveLinesUpAction",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "alt+down",
    "command": "-editor.action.moveLinesDownAction",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "ctrl+shift+e",
    "command": "-workbench.view.explorer",
    "when": "viewContainer.workbench.view.explorer.enabled"
  },
  {
    "key": "ctrl+shift+e",
    "command": "workbench.action.quickOpenNavigatePreviousInFilePicker",
    "when": "inFilesPicker && inQuickOpen"
  },
  {
    "key": "ctrl+b",
    "command": "-workbench.action.toggleSidebarVisibility"
  },
  {
    "key": "ctrl+shift+f",
    "command": "-workbench.action.findInFiles"
  },
  {
    "key": "ctrl+shift+g",
    "command": "-workbench.view.scm",
    "when": "workbench.scm.active"
  },
  {
    "key": "ctrl+shift+d",
    "command": "-workbench.view.debug",
    "when": "viewContainer.workbench.view.debug.enabled"
  },
  {
    "key": "ctrl+shift+m",
    "command": "-workbench.actions.view.problems",
    "when": "workbench.panel.markers.view.active"
  },
  {
    "key": "ctrl+k ctrl+h",
    "command": "-workbench.action.output.toggleOutput",
    "when": "workbench.panel.output.active"
  },
  {
    "key": "ctrl+shift+y",
    "command": "-workbench.debug.action.toggleRepl",
    "when": "workbench.panel.repl.view.active"
  },
  {
    "key": "ctrl+`",
    "command": "-workbench.action.terminal.toggleTerminal",
    "when": "terminal.active"
  },
  {
    "key": "ctrl+j",
    "command": "-workbench.action.togglePanel"
  },
  {
    "key": "ctrl+alt+i",
    "command": "-workbench.panel.chat",
    "when": "workbench.panel.chat.view.copilot.active"
  }, 
  {
    "key": "ctrl+w",
    "command": "-workbench.action.closeActiveEditor"
  },
  {
    "key": "alt+z",
    "command": "-workbench.action.terminal.sizeToContentWidth",
    "when": "terminalFocus && terminalHasBeenCreated && terminalIsOpen || terminalFocus && terminalIsOpen && terminalProcessSupported"
  }
  //                            _   _                           _         
  //  _ __   __ _ ___ ___      | |_| |__  _ __ ___  _   _  __ _| |__  ___ 
  // | '_ \ / _` / __/ __|_____| __| '_ \| '__/ _ \| | | |/ _` | '_ \/ __|
  // | |_) | (_| \__ \__ \_____| |_| | | | | | (_) | |_| | (_| | | | \__ \
  // | .__/ \__,_|___/___/      \__|_| |_|_|  \___/ \__,_|\__, |_| |_|___/
  // |_|                                                  |___/           
  {
    "command": "vscode-neovim.send",
    "key": "alt+k",
    "when": "editorTextFocus && neovim.mode != insert || (terminalFocus)|| (!editorTextFocus ) ",
    "args": "<A-k>",
  },
  //"command": "workbench.action.previousPanelView"
  {
    "command": "vscode-neovim.send",
    "key": "alt+j",
    "when": "(editorTextFocus && neovim.mode != insert) || (!editorTextFocus ) ",
    "args": "<A-j>",
  },
  {
    "command": "vscode-neovim.send",
    "key": "alt+h",
    "when": "(editorTextFocus && neovim.mode != insert) || (!editorTextFocus ) ",
    "args": "<A-h>",
  },
  {
    "command": "vscode-neovim.send",
    "key": "alt+l",
    "when": "(editorTextFocus && neovim.mode != insert) || (!editorTextFocus )",
    "args": "<A-l>",
  },
  {
    // allow to map alt-t in neovim keymaps
    "command": "vscode-neovim.send",
    "key": "alt+t",
    "when": "(editorTextFocus && neovim.mode != insert) || (!editorTextFocus)",
    "args": "<A-t>",
  },
  {
    "command": "vscode-neovim.send",
    "key": "alt+n",
    "when": "(editorTextFocus && neovim.mode != insert) || (!editorTextFocus && !terminalFocus && neovim.mode != 'cmdline')",
    "args": "<A-n>",
  },
  {
    "command": "vscode-neovim.send",
    "key": "alt+left",
    "when": "(editorTextFocus && neovim.mode != insert)",
    "args": "<A-Left>",
  },
  {
    "command": "vscode-neovim.send",
    "key": "alt+right",
    "when": "(editorTextFocus && neovim.mode != insert)",
    "args": "<A-Right>",
  },
  {
    "command": "vscode-neovim.send",
    "key": "alt+up",
    "when": "(editorTextFocus && neovim.mode != insert)",
    "args": "<A-Up>",
  },
  {
    "command": "vscode-neovim.send",
    "key": "alt+down",
    "when": "(editorTextFocus && neovim.mode != insert)",
    "args": "<A-Down>",
  },
  {
    "command": "vscode-neovim.send",
    "key": "alt+shift+j",
    "when": "editorTextFocus && neovim.mode != insert",
    "args": "<A-J>",
  },
  {
    "key": "ctrl+\\",
    "command": "vscode-neovim.send",
    "when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus",
    "args": "<C-\\>",
  },
  {
    "key": "ctrl+n",
    "command": "vscode-neovim.send",
    "when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus",
    "args": "<C-n>",
  },
  {
    "key": "alt+shift+c",
    "command": "vscode-neovim.send",
    "args": "<A-C>",
  },
  {
    "key": "alt+e",
    "command": "vscode-neovim.send",
    "args": "<A-e>",
  },
  {
    "key": "alt+t",
    "command": "vscode-neovim.send",
    "args": "<A-t>",
  },
  {
    "key": "alt+z",
    "command": "vscode-neovim.send",
    "args": "<A-z>",
  },

  //                     _                _      _          _ 
  // __ _____ __ ___  __| |___    _ _ ___| |__ _| |_ ___ __| |
  // \ V (_-</ _/ _ \/ _` / -_)  | '_/ -_) / _` |  _/ -_) _` |
  //  \_//__/\__\___/\__,_\___|  |_| \___|_\__,_|\__\___\__,_|
  //                                                          
  //  _            _    _         _ _              
  // | |_____ _  _| |__(_)_ _  __| (_)_ _  __ _ ___
  // | / / -_) || | '_ \ | ' \/ _` | | ' \/ _` (_-<
  // |_\_\___|\_, |_.__/_|_||_\__,_|_|_||_\__, /__/
  //          |__/                        |___/    
  {
      "key": "ctrl+j",
      "command": "workbench.action.quickOpenNavigateNext",
      "when": "inQuickOpen"
  },
  {
      "key": "ctrl+k",
      "command": "workbench.action.quickOpenNavigatePrevious",
      "when": "inQuickOpen"
  },
  // TODO workbench.action.navigateBack / workbench.action.navigateForward
  {
    "command": "workbench.action.navigateUp",
    "key": "alt+k",
    "when": "terminalFocus",
  },
  {
    "key": "alt+l",
    "command": "workbench.action.terminal.focusNext",
    "when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus"
  },
  {
    "key": "alt+h",
    "command": "workbench.action.terminal.focusPrev",
    "when": "terminalFocus && terminalHasBeenCreated && !terminalEditorFocus || terminalFocus && terminalProcessSupported && !terminalEditorFocus"
  },
  // move up and down in quick fix menu
  {
    "key": "ctrl+j",
    "command": "selectNextCodeAction",
    "when": "codeActionMenuVisible"
  },
  {
    "key": "ctrl+k",
    "command": "selectPrevCodeAction",
    "when": "codeActionMenuVisible"
  },
]